@startuml chess-class-diagram
!pragma layout smetana
skinparam classAttributeIconSize 0

interface GameEngine {
  +executeMove(move, state): MoveResult
}
interface TurnManager {
  +nextPlayer(color, state): Color
}
interface WinCondition {
  +evaluate(state, move): GameStatus
}
interface MoveStrategy {
  +isValidMove(move, piece, state): boolean
}
interface PieceKind {
  +pieceId(): String
}

class Game {
  +executeMove(move): MoveResult
  +undo(): MoveResult
  +redo(): MoveResult
}
class GameHistory
class GameState {
  +board: Board
  +currentPlayer: Color
  +status: GameStatus
  +extra: GameExtra
}
class Board {
  +pieces: Map<Position, Piece>
}
class Piece {
  +color: Color
  +type: PieceKind
  +moveStrategy: MoveStrategy
}

package "model/pieces" {
  class King implements PieceKind
  class Queen implements PieceKind
  class Rook implements PieceKind
  class Bishop implements PieceKind
  class Knight implements PieceKind
  class Pawn implements PieceKind
}

class ChessExtra {
  +castlingRights: CastlingRights
  +enPassantTarget: Optional<Position>
}
class ChessPieceFactory {
  +king(color): Piece
  +queen(color): Piece
  +rook(color): Piece
  +bishop(color): Piece
  +knight(color): Piece
  +pawn(color): Piece
}
class CheckmateWinCondition implements WinCondition
class ExtinctionWinCondition implements WinCondition {
  -requiredTypes: Set<PieceKind>
}
class StandardTurnManager implements TurnManager
class ProgressiveTurnManager implements TurnManager
class PawnMoveStrategy implements MoveStrategy
class BerolinaPawnMoveStrategy implements MoveStrategy
class KingMoveStrategy implements MoveStrategy
class ChessGameEngine implements GameEngine {
  -moveValidator: ChessMoveValidator
  -winCondition: WinCondition
  -turnManager: TurnManager
}
class ChessGameFactory {
  +createStandardGame(): Game
  +createExtinctionGame(): Game
  +createProgressiveGame(): Game
  +createBerlineseGame(): Game
}

Game --> GameEngine
Game --> GameHistory
GameHistory --> GameState
GameState --> Board
Board --> Piece
Piece --> PieceKind
Piece --> MoveStrategy
ChessGameEngine --> TurnManager
ChessGameEngine --> WinCondition
ChessGameFactory ..> Game : creates
ChessPieceFactory ..> Piece : creates

@enduml