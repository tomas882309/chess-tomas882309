@startuml checkers-sequence-diagram

actor Client
participant Game
participant GameEngineImpl
participant CompositeValidator
participant BoardUpdater

Client -> Game : executeMove(move)
Game -> GameEngineImpl : executeMove(move, state)

GameEngineImpl -> CompositeValidator : findViolation(move, state)
note right : PieceExists, CorrectTurn, InBounds,\nPieceMove, MultiCaptureOnly,\nMandatoryCapture
CompositeValidator --> GameEngineImpl : Optional.empty()

GameEngineImpl -> BoardUpdater : apply(move, state)
note right : CaptureEffect,\nPromotionEffect
BoardUpdater --> GameEngineImpl : newBoard

GameEngineImpl -> GameEngineImpl : buildNextState(move, state, newBoard)
note right : extraState.update() primero\n→ CheckersTurnManager lee\nMultiCaptureExtraState\n→ mismo jugador si puede\nseguir capturando

alt puede seguir capturando
  GameEngineImpl --> Game : MoveResult.Success(mismoJugador)
  Game --> Client : GameResult.Moved(newGame)
  Client -> Game : executeMove(segundoSalto)
else fin de turno
  GameEngineImpl --> Game : MoveResult.Success(jugadorAlternado)
  Game --> Client : GameResult.Moved(newGame)
end

@enduml